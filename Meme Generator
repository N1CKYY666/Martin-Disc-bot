import discord 
import os
import random
from discord.ext import commands
import requests
import aiohttp

intents = discord.Intents.default()
intents.message_content = True

bot = commands.Bot(command_prefix='$', intents=intents)

@bot.event
async def on_ready():
    print(f'We have logged in as {bot.user}')

@bot.command()
async def album(ctx):
    image_name = random.choice(os.listdir("imagesmom"))
    with open(f'imagesmom/{image_name}', 'rb') as f:
        picture = discord.File(f)
    await ctx.send(file=picture)

bot.run("TOKEN_HERE")
